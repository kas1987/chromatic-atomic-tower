{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cat.local/schemas/finding.schema.json",
  "title": "LOGHOUSE Finding",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "finding_id",
    "title",
    "category",
    "severity",
    "confidence",
    "status",
    "services",
    "first_seen",
    "last_seen",
    "owner",
    "hypothesis",
    "suggested_fix",
    "blast_radius",
    "sla_impact",
    "evidence"
  ],
  "properties": {
    "finding_id": {
      "type": "string",
      "format": "uuid"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "category": {
      "type": "string",
      "enum": ["reliability", "performance", "security", "drift", "governance", "aiops"]
    },
    "severity": {
      "type": "string",
      "enum": ["p0", "p1", "p2", "p3"]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "status": {
      "type": "string",
      "enum": ["open", "triaged", "in_progress", "mitigated", "resolved", "dismissed"]
    },
    "services": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "first_seen": {
      "type": "string",
      "format": "date-time"
    },
    "last_seen": {
      "type": "string",
      "format": "date-time"
    },
    "owner": {
      "type": "string",
      "minLength": 1
    },
    "hypothesis": {
      "type": "string",
      "minLength": 1
    },
    "suggested_fix": {
      "type": "string",
      "minLength": 1
    },
    "blast_radius": {
      "type": "string",
      "enum": ["service", "domain", "platform", "org", "bead", "sprint"]
    },
    "sla_impact": {
      "type": "boolean"
    },
    "ticket_url": {
      "type": "string",
      "format": "uri"
    },
    "evidence": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["source_type", "source_ref", "observed_at", "summary"],
        "properties": {
          "source_type": {
            "type": "string",
            "enum": [
              "log", "metric", "trace", "dependency", "deploy", "git", "catalog",
              "transition_log", "go_decisions", "closeouts", "agent_run_log"
            ]
          },
          "source_ref": {
            "type": "string",
            "minLength": 1
          },
          "observed_at": {
            "type": "string",
            "format": "date-time"
          },
          "summary": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
