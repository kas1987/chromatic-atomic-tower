{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chromatic.local/schemas/tool_plane_database.schema.json",
  "title": "Database Tool Plane",
  "description": "Governance descriptor for the Database tool plane. Read-only by default; references credentials by NAME only (never a live DSN/secret).",
  "type": "object",
  "additionalProperties": false,
  "required": ["plane", "engines", "capabilities", "default_mode"],
  "properties": {
    "plane": {"const": "database"},
    "engines": {
      "type": "array",
      "items": {"type": "string", "enum": ["sqlite", "postgres", "mysql", "duckdb"]},
      "uniqueItems": true
    },
    "capabilities": {
      "type": "array",
      "items": {"type": "string", "enum": ["query", "read", "write", "migrate"]},
      "uniqueItems": true
    },
    "default_mode": {"type": "string", "enum": ["read_only", "read_write"], "default": "read_only"},
    "connection_ref": {
      "type": "string",
      "description": "A NAMED reference resolved out-of-band — never a live DSN or credential."
    },
    "allowed_databases": {"type": "array", "items": {"type": "string"}},
    "forbidden_operations": {"type": "array", "items": {"type": "string"}}
  }
}
