{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chromatic.local/schemas/tower_guard_report.schema.json",
  "title": "CAT Tower Guard Report",
  "type": "object",
  "required": [
    "version",
    "generated_at",
    "root",
    "status",
    "checks"
  ],
  "properties": {
    "version": {
      "type": "string"
    },
    "generated_at": {
      "type": "string"
    },
    "root": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": ["pass", "fail"]
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "status", "ok", "issues"],
        "properties": {
          "name": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": ["pass", "fail"]
          },
          "ok": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "issues": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    }
  }
}
