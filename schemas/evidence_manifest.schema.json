{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CAT Evidence Manifest",
  "description": "Index of all evidence artifacts produced during BEAD execution.",
  "type": "object",
  "required": ["schema_version", "evidence"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Manifest schema version, e.g. 0.1.0"
    },
    "generated_at": {
      "type": "string",
      "description": "ISO-8601 timestamp when manifest was last rebuilt"
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "evidence_id",
          "mission_id",
          "bead_id",
          "artifact_path",
          "artifact_type",
          "generated_at",
          "sha256"
        ],
        "properties": {
          "evidence_id": {
            "type": "string",
            "description": "Unique identifier for this evidence entry"
          },
          "mission_id": {"type": "string"},
          "bead_id": {"type": "string"},
          "artifact_path": {
            "type": "string",
            "description": "Relative path from repo root to artifact"
          },
          "artifact_type": {
            "type": "string",
            "enum": ["test_output", "closeout_report", "validation_log", "diff", "screenshot", "bundle", "other"]
          },
          "generated_at": {
            "type": "string",
            "description": "ISO-8601 timestamp"
          },
          "validator": {
            "type": "string",
            "description": "Agent or script that produced the artifact"
          },
          "sha256": {
            "type": "string",
            "description": "SHA-256 hex digest of artifact content",
            "pattern": "^[0-9a-f]{64}$"
          }
        }
      }
    }
  }
}
