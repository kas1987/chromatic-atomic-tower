{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chromatic.local/schemas/archive.schema.json",
  "title": "CAT Evidence Archive Record",
  "type": "object",
  "required": [
    "timestamp",
    "source_path",
    "destination_path",
    "file_size_bytes",
    "event",
    "eligibility"
  ],
  "properties": {
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of archival operation"
    },
    "source_path": {
      "type": "string",
      "description": "Original path in evidence/ before archival"
    },
    "destination_path": {
      "type": "string",
      "description": "Destination path in evidence/archive/YYYY/QN/ after archival"
    },
    "file_size_bytes": {
      "type": "integer",
      "minimum": 0,
      "description": "Size of archived file in bytes"
    },
    "event": {
      "type": "string",
      "enum": [
        "archived",
        "skipped",
        "failed"
      ],
      "description": "Outcome of archival operation"
    },
    "eligibility": {
      "type": "string",
      "enum": [
        "eligible",
        "exempted",
        "unknown"
      ],
      "description": "Eligibility classification for archival"
    },
    "reason": {
      "type": "string",
      "description": "Reason if skipped or failed (optional)"
    },
    "git_commit_sha": {
      "type": [
        "string",
        "null"
      ],
      "description": "Git commit SHA if changes committed immediately"
    },
    "age_days": {
      "type": "number",
      "minimum": 0,
      "description": "Age of evidence in days at time of archival"
    },
    "archival_batch_id": {
      "type": "string",
      "description": "Batch ID for grouping related archival operations"
    }
  },
  "examples": [
    {
      "timestamp": "2026-06-21T12:00:00Z",
      "source_path": "evidence/ci/cat_ci_report_MP_CAT_A011_4C01.json",
      "destination_path": "evidence/archive/2026/Q2/cat_ci_report_MP_CAT_A011_4C01.json",
      "file_size_bytes": 45000,
      "event": "archived",
      "eligibility": "eligible",
      "age_days": 94,
      "git_commit_sha": "abc123def456",
      "archival_batch_id": "batch_2026_06_21_001"
    },
    {
      "timestamp": "2026-06-21T12:00:00Z",
      "source_path": "agents/scorecards/BEAD-CAT-A011-4C01-01_Builder_bead_completed.yaml",
      "destination_path": null,
      "file_size_bytes": 256,
      "event": "skipped",
      "eligibility": "exempted",
      "reason": "scorecard records retained indefinitely",
      "age_days": 100,
      "archival_batch_id": "batch_2026_06_21_001"
    },
    {
      "timestamp": "2026-06-21T12:00:00Z",
      "source_path": "evidence/logs/transitions.jsonl",
      "destination_path": null,
      "file_size_bytes": 12000,
      "event": "skipped",
      "eligibility": "exempted",
      "reason": "learnings and logs retained indefinitely",
      "age_days": 150,
      "archival_batch_id": "batch_2026_06_21_001"
    }
  ]
}
