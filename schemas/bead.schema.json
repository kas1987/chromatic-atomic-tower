{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chromatic.local/schemas/bead.schema.json",
  "title": "CAT BEAD",
  "type": "object",
  "required": [
    "bead_id",
    "mission_id",
    "title",
    "status",
    "agent_role",
    "autonomy_level",
    "objective",
    "allowed_paths",
    "forbidden_paths",
    "tool_budget",
    "confidence",
    "risk_level",
    "reversibility",
    "stop_conditions",
    "definition_of_done",
    "validation",
    "required_output",
    "handoff"
  ],
  "properties": {
    "bead_id": {
      "type": "string",
      "pattern": "^BEAD-[A-Z0-9-]+$"
    },
    "mission_id": {
      "type": "string",
      "pattern": "^MP-[A-Z0-9-]+$"
    },
    "title": {
      "type": "string",
      "minLength": 3
    },
    "status": {
      "type": "string",
      "enum": [
        "queued",
        "active",
        "in_progress",
        "validating",
        "reviewed",
        "completed",
        "blocked",
        "failed",
        "changes_requested",
        "archived"
      ]
    },
    "agent_role": {
      "type": "string"
    },
    "autonomy_level": {
      "type": "string",
      "enum": [
        "L0",
        "L1",
        "L2",
        "L3",
        "L4",
        "L5"
      ]
    },
    "objective": {
      "type": "string",
      "minLength": 10
    },
    "allowed_paths": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "forbidden_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "tool_budget": {
      "$ref": "#/$defs/tool_budget"
    },
    "confidence": {
      "$ref": "#/$defs/confidence"
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high",
        "critical"
      ]
    },
    "reversibility": {
      "type": "string",
      "enum": [
        "high",
        "medium",
        "low",
        "none"
      ]
    },
    "stop_conditions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "definition_of_done": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "validation": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/validation"
      }
    },
    "required_output": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "handoff": {
      "type": "object"
    }
  },
  "$defs": {
    "tool_budget": {
      "type": "object",
      "required": [
        "search",
        "read",
        "write",
        "execute",
        "max_runtime_minutes"
      ],
      "properties": {
        "search": {
          "type": "integer",
          "minimum": 0
        },
        "read": {
          "type": "integer",
          "minimum": 0
        },
        "write": {
          "type": "integer",
          "minimum": 0
        },
        "execute": {
          "type": "integer",
          "minimum": 0
        },
        "max_runtime_minutes": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "validation": {
      "type": "object",
      "required": [
        "type",
        "command",
        "evidence_path",
        "required"
      ],
      "properties": {
        "type": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "evidence_path": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "confidence": {
      "type": "object",
      "required": [
        "minimum",
        "current",
        "objective_clarity",
        "scope_clarity",
        "evidence_quality",
        "reversibility",
        "tool_fit",
        "risk_awareness",
        "testability"
      ],
      "properties": {
        "minimum": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "current": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "objective_clarity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "scope_clarity": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "evidence_quality": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "reversibility": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "tool_fit": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "risk_awareness": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        },
        "testability": {
          "type": "integer",
          "minimum": 0,
          "maximum": 100
        }
      }
    }
  },
  "additionalProperties": true
}
