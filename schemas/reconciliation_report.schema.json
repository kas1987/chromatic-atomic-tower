{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "CAT Reconciliation Report",
  "type": "object",
  "required": [
    "report_id",
    "status",
    "active_mission_id",
    "checks"
  ],
  "properties": {
    "report_id": {
      "type": "string"
    },
    "status": {
      "type": "string",
      "enum": [
        "passed",
        "failed"
      ]
    },
    "active_mission_id": {
      "type": "string"
    },
    "next_mission_id": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "name",
          "passed"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "passed": {
            "type": "boolean"
          },
          "details": {
            "type": "string"
          }
        }
      }
    },
    "missing": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
